{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "script/schema/05-architecture/module-boundary-diff.schema.json",
  "type": "object",
  "required": ["check", "domain", "category", "status", "metrics", "executed_at", "repo_fingerprint"],
  "properties": {
    "check": { "const": "module-boundary-diff" },
    "domain": { "const": "05-architecture" },
    "category": { "const": "A" },
    "status": { "enum": ["pass", "fail", "error", "not_applicable"] },
    "metrics": {
      "type": "object",
      "required": ["declared_modules", "actual_modules", "boundary_violations"],
      "properties": {
        "declared_modules": { "type": "integer", "minimum": 0 },
        "actual_modules": { "type": "integer", "minimum": 0 },
        "boundary_violations": { "type": "integer", "minimum": 0 }
      }
    },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "executed_at": { "type": "string", "format": "date-time" },
    "repo_fingerprint": { "type": "string" }
  },
  "if": { "properties": { "status": { "const": "not_applicable" } } },
  "then": { "required": ["evidence"], "properties": { "evidence": { "minItems": 1 } } }
}
