{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "script/schema/06-design/design-tokens-in-implementation.schema.json",
  "type": "object",
  "required": ["check", "domain", "category", "status", "metrics", "executed_at", "repo_fingerprint"],
  "properties": {
    "check": { "const": "design-tokens-in-implementation" },
    "domain": { "const": "06-design" },
    "category": { "const": "B" },
    "status": { "enum": ["pass", "fail", "error", "not_applicable"] },
    "metrics": {
      "type": "object",
      "required": ["tokens_declared", "tokens_found", "tokens_missing"],
      "properties": {
        "tokens_declared": { "type": "integer", "minimum": 0 },
        "tokens_found": { "type": "integer", "minimum": 0 },
        "tokens_missing": { "type": "integer", "minimum": 0 }
      }
    },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "executed_at": { "type": "string", "format": "date-time" },
    "repo_fingerprint": { "type": "string" }
  },
  "if": { "properties": { "status": { "const": "not_applicable" } } },
  "then": { "required": ["evidence"], "properties": { "evidence": { "minItems": 1 } } }
}
