{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "script/schema/08-external-context/dependency-reachable.schema.json",
  "type": "object",
  "required": ["check", "domain", "category", "status", "metrics", "executed_at", "repo_fingerprint"],
  "properties": {
    "check": { "const": "dependency-reachable" },
    "domain": { "const": "08-external-context" },
    "category": { "const": "A" },
    "status": { "enum": ["pass", "fail", "error", "not_applicable"] },
    "metrics": {
      "type": "object",
      "required": ["dependencies_checked", "dependencies_reachable"],
      "properties": {
        "dependencies_checked": { "type": "integer", "minimum": 0 },
        "dependencies_reachable": { "type": "integer", "minimum": 0 }
      }
    },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "executed_at": { "type": "string", "format": "date-time" },
    "repo_fingerprint": { "type": "string" }
  },
  "if": { "properties": { "status": { "const": "not_applicable" } } },
  "then": { "required": ["evidence"], "properties": { "evidence": { "minItems": 1 } } }
}
