{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "script/schema/11-prototype/mock-api-runs.schema.json",
  "type": "object",
  "required": ["check", "domain", "category", "status", "metrics", "executed_at", "repo_fingerprint"],
  "properties": {
    "check": { "const": "mock-api-runs" },
    "domain": { "const": "11-prototype" },
    "category": { "const": "A" },
    "status": { "enum": ["pass", "fail", "error", "not_applicable"] },
    "metrics": {
      "type": "object",
      "required": ["server_started", "endpoints_tested", "endpoints_passed"],
      "properties": {
        "server_started": { "type": "boolean" },
        "endpoints_tested": { "type": "integer", "minimum": 0 },
        "endpoints_passed": { "type": "integer", "minimum": 0 }
      }
    },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "executed_at": { "type": "string", "format": "date-time" },
    "repo_fingerprint": { "type": "string" }
  },
  "if": { "properties": { "status": { "const": "not_applicable" } } },
  "then": { "required": ["evidence"], "properties": { "evidence": { "minItems": 1 } } }
}
