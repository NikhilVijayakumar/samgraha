{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "script/schema/12-qa/unit-test-coverage.schema.json",
  "type": "object",
  "required": ["check", "domain", "category", "status", "metrics", "executed_at", "repo_fingerprint"],
  "properties": {
    "check": { "const": "unit-test-coverage" },
    "domain": { "const": "12-qa" },
    "category": { "const": "A" },
    "status": { "enum": ["pass", "fail", "error", "not_applicable"] },
    "metrics": {
      "type": "object",
      "required": ["source_files", "tested_files", "coverage_percent"],
      "properties": {
        "source_files": { "type": "integer", "minimum": 0 },
        "tested_files": { "type": "integer", "minimum": 0 },
        "coverage_percent": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "executed_at": { "type": "string", "format": "date-time" },
    "repo_fingerprint": { "type": "string" }
  },
  "if": { "properties": { "status": { "const": "not_applicable" } } },
  "then": { "required": ["evidence"], "properties": { "evidence": { "minItems": 1 } } }
}
