{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "script/schema/_generic/traceability-refs-exist.schema.json",
  "type": "object",
  "required": ["check", "domain", "category", "status", "metrics", "executed_at", "repo_fingerprint"],
  "properties": {
    "check": { "const": "traceability-refs-exist" },
    "domain": { "const": "_generic" },
    "category": { "const": "C" },
    "status": { "enum": ["pass", "fail", "error", "not_applicable"] },
    "metrics": {
      "type": "object",
      "required": ["domains_checked", "refs_found", "refs_valid", "refs_missing"],
      "properties": {
        "domains_checked": { "type": "integer", "minimum": 0 },
        "refs_found": { "type": "integer", "minimum": 0 },
        "refs_valid": { "type": "integer", "minimum": 0 },
        "refs_missing": { "type": "integer", "minimum": 0 }
      }
    },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "executed_at": { "type": "string", "format": "date-time" },
    "repo_fingerprint": { "type": "string" }
  },
  "if": { "properties": { "status": { "const": "not_applicable" } } },
  "then": { "required": ["evidence"], "properties": { "evidence": { "minItems": 1 } } }
}
